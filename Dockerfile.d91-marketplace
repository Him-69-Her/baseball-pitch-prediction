FROM python:3.11-slim
WORKDIR /app

ENV PIP_ROOT_USER_ACTION=ignore
ENV DEBIAN_FRONTEND=noninteractive

RUN pip install --upgrade pip && pip install --no-cache-dir google-cloud-pubsub requests

COPY d91_marketplace_live.py weather_feed.py matching_engine.py battery_vpp.py pricing_agent.py service_wrapper.py ./

CMD ["python3", "-u", "service_wrapper.py"]
